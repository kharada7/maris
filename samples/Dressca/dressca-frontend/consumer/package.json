{
  "name": "consumer",
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --mode dev",
    "mock": "vite --mode mock",
    "build:dev": "run-p type-check build-only:dev --print-label",
    "build:prod": "run-p type-check build-only:prod --print-label",
    "preview": "vite preview",
    "test:unit": "vitest",
    "prepare": "cypress install",
    "test:e2e": "start-server-and-test dev http://localhost:5173/ 'cypress open --e2e --browser chrome'",
    "test:e2e:ci": "start-server-and-test dev http://localhost:5173/ 'cypress run'",
    "build-only:dev": "vite build --mode dev",
    "build-only:prod": "vite build --mode prod",
    "type-check": "vue-tsc --build",
    "lint": "run-s eslint stylelint format --print-label",
    "lint:ci": "run-p eslint:ci format:ci stylelint:ci --print-label",
    "eslint": "eslint . --fix",
    "eslint:ci": "eslint .",
    "stylelint": "stylelint **/*.{vue,css} --fix",
    "stylelint:ci": "stylelint **/*.{vue,css}",
    "format": "prettier --write .",
    "format:ci": "prettier --check .",
    "generate-client": "openapi-generator-cli batch ./openapisettings.json --clean",
    "coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@heroicons/vue": "2.2.0",
    "@vueuse/core": "14.2.1",
    "axios": "1.13.6",
    "pinia": "3.0.4",
    "vee-validate": "4.15.1",
    "vue": "3.5.30",
    "vue-i18n": "11.3.0",
    "vue-router": "5.0.3",
    "yup": "1.7.1"
  },
  "devDependencies": {
    "@openapitools/openapi-generator-cli": "2.30.2",
    "@pinia/testing": "1.0.3",
    "@tailwindcss/vite": "4.2.1",
    "@tsconfig/node24": "24.0.4",
    "@types/jsdom": "28.0.0",
    "@types/node": "25.5.0",
    "@vitejs/plugin-vue": "6.0.5",
    "@vitejs/plugin-vue-jsx": "5.1.5",
    "@vitest/coverage-v8": "4.0.18",
    "@vitest/eslint-plugin": "1.6.12",
    "@vue/eslint-config-typescript": "14.7.0",
    "@vue/test-utils": "2.4.6",
    "@vue/tsconfig": "0.9.0",
    "cypress": "15.11.0",
    "eslint": "9.39.4",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-cypress": "5.3.0",
    "eslint-plugin-jsdoc": "62.8.0",
    "eslint-plugin-vue": "10.8.0",
    "jiti": "2.6.1",
    "jsdom": "29.0.0",
    "msw": "2.12.12",
    "npm-run-all2": "8.0.4",
    "prettier": "3.8.1",
    "prettier-plugin-tailwindcss": "0.7.2",
    "start-server-and-test": "2.1.5",
    "stylelint": "16.26.1",
    "stylelint-config-recommended-vue": "1.6.1",
    "stylelint-config-standard": "39.0.1",
    "tailwindcss": "4.2.1",
    "typescript": "5.9.3",
    "vite": "7.3.1",
    "vite-plugin-vue-devtools": "8.1.0",
    "vitest": "4.0.18",
    "vue-tsc": "3.2.5"
  },
  "engines": {
    "node": "^24.14.0",
    "npm": "^11.9.0"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}
