{
  "name": "app",
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --mode dev",
    "mock": "vite --mode mock",
    "build:dev": "run-p type-check build-only:dev --print-label",
    "build:prod": "run-p type-check build-only:prod --print-label",
    "preview": "vite preview",
    "test:unit": "vitest",
    "type-check": "vue-tsc --build",
    "lint": "run-s eslint format --print-label",
    "lint:ci": "run-p eslint:ci format:ci --print-label",
    "build-only:dev": "vite build --mode dev",
    "build-only:prod": "vite build --mode prod",
    "eslint": "eslint . --fix --cache",
    "eslint:ci": "eslint . --cache",
    "format": "prettier --write .",
    "format:ci": "prettier --check .",
    "generate-client": "openapi-generator-cli batch ./openapisettings.json --clean",
    "coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@azure/msal-browser": "4.27.0",
    "axios": "1.13.6",
    "pinia": "3.0.4",
    "vue": "3.5.30"
  },
  "devDependencies": {
    "@openapitools/openapi-generator-cli": "2.30.2",
    "@pinia/testing": "1.0.3",
    "@tsconfig/node24": "24.0.4",
    "@types/jsdom": "28.0.0",
    "@types/node": "25.5.0",
    "@vitejs/plugin-vue": "6.0.5",
    "@vitejs/plugin-vue-jsx": "5.1.5",
    "@vitest/coverage-v8": "4.0.18",
    "@vitest/eslint-plugin": "1.6.12",
    "@vue/eslint-config-typescript": "14.7.0",
    "@vue/test-utils": "2.4.6",
    "@vue/tsconfig": "0.9.0",
    "eslint": "9.39.4",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-jsdoc": "62.8.0",
    "eslint-plugin-vue": "10.8.0",
    "jiti": "2.6.1",
    "jsdom": "29.0.0",
    "msw": "2.12.10",
    "npm-run-all2": "8.0.4",
    "prettier": "3.8.1",
    "typescript": "5.9.3",
    "vite": "7.3.1",
    "vite-plugin-vue-devtools": "8.1.0",
    "vitest": "4.0.18",
    "vue-tsc": "3.2.5"
  },
  "engines": {
    "node": "^24.14.0",
    "npm": "^11.9.0"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}
